# E.F.A.S. Environment Variables
# I-copy ito bilang .env sa backend folder
# HUWAG i-commit sa GitHub ang .env!

# Server
PORT=5000

# MySQL Database (baguhin ayon sa inyong Navicat setup)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=efas_db

# JWT Secret (palitan ng mahabang random string)
JWT_SECRET=efas_solano_nv_super_secret_key_2024_change_this

# JWT Expiry
JWT_EXPIRES_IN=8h

# Frontend URL (para sa CORS)
FRONTEND_URL=http://localhost:3000
